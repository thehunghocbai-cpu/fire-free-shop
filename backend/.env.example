# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/fire_free_shop
# For MongoDB Atlas use:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/fire_free_shop

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production_12345
JWT_EXPIRE=7d
JWT_ADMIN_SECRET=your_admin_jwt_secret_key_here_change_this_in_production

# Email (Gmail - use App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_from_gmail
EMAIL_FROM=noreply@firefreeshop.com

# Client URL
CLIENT_URL=http://localhost:8000

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@firefreeshop.com
ADMIN_PASSWORD=Admin@123
